# Application
NODE_ENV=development
PORT=3001
API_VERSION=v1

# Database (AWS RDS PostgreSQL)
DATABASE_URL=postgresql://user:password@db-dev.xxxxxxxx.eu-central-1.rds.amazonaws.com:5432/hotel_crm?schema=public&sslmode=require

# Redis (Optional - for caching)
REDIS_URL=redis://localhost:6379

# JWT (two separate secrets — access tokens use JWT_SECRET, refresh tokens use JWT_REFRESH_SECRET)
JWT_SECRET=your-access-token-secret-min-32-characters-here
JWT_REFRESH_SECRET=your-refresh-token-secret-min-32-chars-here
JWT_ACCESS_EXPIRY=1h
JWT_REFRESH_EXPIRY=7d

# Logging
LOG_LEVEL=info

# CORS & URLs
CORS_ORIGIN=http://localhost:3000
FRONTEND_URL=http://localhost:3000

# AWS S3 (File Storage)
# In deployed environments prefer the EC2 instance role over static keys.
AWS_REGION=eu-central-1
S3_BUCKET=hotelcrm-uploads
S3_BUCKET_BACKUPS=hotelcrm-backups
# AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY only when not using an instance role
# AWS_ACCESS_KEY_ID=your-access-key-id
# AWS_SECRET_ACCESS_KEY=your-secret-access-key

# Email Service (SendGrid or Resend)
EMAIL_SERVICE=sendgrid
SENDGRID_API_KEY=your-sendgrid-key
# RESEND_API_KEY=your-resend-key

# Apple Push Notifications (APNs)
# Encode key: base64 < AuthKey_XXXXXXXXXX.p8 | tr -d '\n'
APNS_PRIVATE_KEY_BASE64=base64-encoded-content-of-your-p8-key-file
APNS_KEY_ID=your-key-id
APNS_TEAM_ID=your-team-id
APNS_BUNDLE_ID=com.zirove.hotelcrm

# Firebase Cloud Messaging (FCM)
FIREBASE_PROJECT_ID=your-firebase-project-id

# Error Tracking (Sentry)
SENTRY_DSN=https://your-sentry-dsn@sentry.io/project
