# backend/.env.staging — Staging environment template (safe defaults only, no secrets)
# Real secrets live in /etc/hotel-crm/.env on the Staging Droplet (chmod 640)
NODE_ENV=staging
PORT=3001
API_VERSION=v1

# Database — replace with actual staging cluster URL
DATABASE_URL=postgresql://user:password@db-staging.ondigitalocean.com:25060/hotelcrm_staging?sslmode=require

# Redis — Docker on Staging Droplet
REDIS_URL=redis://:REDIS_PASSWORD@127.0.0.1:6379

# JWT — generate with: openssl rand -base64 48
JWT_SECRET=REPLACE_WITH_STAGING_JWT_SECRET
JWT_REFRESH_SECRET=REPLACE_WITH_STAGING_JWT_REFRESH_SECRET
JWT_ACCESS_EXPIRY=1h
JWT_REFRESH_EXPIRY=7d

# CORS
CORS_ORIGIN=https://staging.hotelcrm.app
FRONTEND_URL=https://staging.hotelcrm.app

# DigitalOcean Spaces — use the same dev bucket (separate from prod)
DO_SPACES_KEY=REPLACE_WITH_SPACES_KEY
DO_SPACES_SECRET=REPLACE_WITH_SPACES_SECRET
DO_SPACES_BUCKET=hotelcrm-staging
DO_SPACES_REGION=fra1
DO_SPACES_ENDPOINT=https://fra1.digitaloceanspaces.com

# Email
EMAIL_SERVICE=sendgrid
SENDGRID_API_KEY=REPLACE_WITH_SENDGRID_KEY

# APNs — use a staging/development APNs key, not production
APNS_PRIVATE_KEY_BASE64=REPLACE_WITH_BASE64_ENCODED_P8
APNS_KEY_ID=REPLACE_WITH_KEY_ID
APNS_TEAM_ID=REPLACE_WITH_TEAM_ID
APNS_BUNDLE_ID=com.zirove.hotelcrm.staging

# Firebase
FIREBASE_PROJECT_ID=REPLACE_WITH_FIREBASE_PROJECT_ID

# Sentry — staging project DSN
SENTRY_DSN=REPLACE_WITH_STAGING_SENTRY_DSN
LOG_LEVEL=debug
