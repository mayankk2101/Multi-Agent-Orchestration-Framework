# backend/.env.staging — Staging environment template (safe defaults only, no secrets)
# Real secrets live in /etc/hotel-crm/.env on the Staging EC2 instance (chmod 640)
# or in AWS Secrets Manager (hotel-crm/staging).
NODE_ENV=staging
PORT=3001
API_VERSION=v1

# Database — replace with actual staging RDS endpoint
DATABASE_URL=postgresql://user:password@db-staging.xxxxxxxx.eu-central-1.rds.amazonaws.com:5432/hotelcrm_staging?schema=public&sslmode=require

# Redis — Docker on the Staging EC2 instance
REDIS_URL=redis://:REDIS_PASSWORD@127.0.0.1:6379

# JWT — generate with: openssl rand -base64 48
JWT_SECRET=REPLACE_WITH_STAGING_JWT_SECRET
JWT_REFRESH_SECRET=REPLACE_WITH_STAGING_JWT_REFRESH_SECRET
JWT_ACCESS_EXPIRY=1h
JWT_REFRESH_EXPIRY=7d

# CORS
CORS_ORIGIN=https://staging.hotelcrm.app
FRONTEND_URL=https://staging.hotelcrm.app

# AWS S3 — staging bucket (separate from prod). Prefer the EC2 instance role.
AWS_REGION=eu-central-1
S3_BUCKET=hotelcrm-staging
S3_BUCKET_BACKUPS=hotelcrm-backups-staging
# AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY only when not using an instance role
# AWS_ACCESS_KEY_ID=REPLACE_WITH_ACCESS_KEY_ID
# AWS_SECRET_ACCESS_KEY=REPLACE_WITH_SECRET_ACCESS_KEY

# Email
EMAIL_SERVICE=sendgrid
SENDGRID_API_KEY=REPLACE_WITH_SENDGRID_KEY

# APNs — use a staging/development APNs key, not production
APNS_PRIVATE_KEY_BASE64=REPLACE_WITH_BASE64_ENCODED_P8
APNS_KEY_ID=REPLACE_WITH_KEY_ID
APNS_TEAM_ID=REPLACE_WITH_TEAM_ID
APNS_BUNDLE_ID=com.zirove.hotelcrm.staging

# Firebase
FIREBASE_PROJECT_ID=REPLACE_WITH_FIREBASE_PROJECT_ID

# Sentry — staging project DSN
SENTRY_DSN=REPLACE_WITH_STAGING_SENTRY_DSN
LOG_LEVEL=debug
