// =============================================================================
// Hotel CRM — PRISMA_SCHEMA_V2
// Architecture: Marketplace (hotels post requests, workers apply)
// Removed: Room, Task, TaskPhoto, DailyOperation
// Added: HotelWorker, WorkApplication, Attendance
// =============================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// =============================================================================
// ENUMS
// =============================================================================

enum UserRole {
  WORKER
  CHECKER
  MANAGER
  ADMIN
}

enum HotelWorkerStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum WorkRequestStatus {
  DRAFT
  OPEN
  PARTIALLY_FILLED
  FILLED
  CANCELLED
  EXPIRED
}

enum ApplicationStatus {
  PENDING
  ACCEPTED
  REJECTED
  WITHDRAWN
  EXPIRED
}

enum AssignmentStatus {
  CONFIRMED
  IN_PROGRESS
  COMPLETED
  NO_SHOW
  CANCELLED
  REASSIGNED
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
  PARTIAL
  EXCUSED
}

enum VerificationStatus {
  PASSED
  FAILED
  NEEDS_REWORK
}

enum NotificationChannel {
  IN_APP
  EMAIL
  PUSH
  SMS
}

// =============================================================================
// AUTH MODULE
// =============================================================================

model User {
  id                 String    @id @default(cuid())
  email              String    @unique
  password_hash      String
  first_name         String
  last_name          String
  phone              String?   @unique
  profile_photo_url  String?
  role               UserRole  @default(WORKER)
  permissions        String[]  // granular permission codes e.g. ["work_request:read"]
  is_active          Boolean   @default(true)
  email_verified_at  DateTime?
  phone_verified_at  DateTime?
  last_login_at      DateTime?
  deleted_at         DateTime? // GDPR soft delete — keep row, null PII via separate job
  created_at         DateTime  @default(now())
  updated_at         DateTime  @updatedAt

  // Relations
  sessions                  Session[]
  hotel_workers             HotelWorker[]
  work_applications         WorkApplication[]       @relation("applicant")
  reviewed_applications     WorkApplication[]       @relation("application_reviewer")
  assignments               WorkerAssignment[]      @relation("assigned_worker")
  assignments_managed       WorkerAssignment[]      @relation("assignment_manager")
  attendance_records        Attendance[]            @relation("attendee")
  attendance_verified       Attendance[]            @relation("attendance_verifier")
  verifications_performed   QualityVerification[]   @relation("verifier")
  ratings_received          Rating[]                @relation("rated_worker")
  ratings_given             Rating[]                @relation("rater")
  overall_rating            WorkerOverallRating?
  notifications             Notification[]
  created_work_requests     WorkRequest[]           @relation("request_creator")
  audit_logs                AuditLog[]

  @@index([role])
  @@index([is_active])
  @@index([deleted_at])
}

model Session {
  id            String   @id @default(cuid())
  user_id       String
  user          User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  refresh_token String   @unique
  device_info   String?
  ip_address    String?
  expires_at    DateTime
  created_at    DateTime @default(now())

  @@index([user_id])
  @@index([expires_at])
}

// =============================================================================
// HOTEL MODULE
// =============================================================================

model Hotel {
  id            String   @id @default(cuid())
  name          String
  city          String
  country       String   @default("Germany")
  address       String
  timezone      String   @default("Europe/Berlin")
  contact_email String?
  contact_phone String?
  is_active     Boolean  @default(true)
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  // Relations
  hotel_workers    HotelWorker[]
  work_requests    WorkRequest[]
  assignments      WorkerAssignment[]
  attendance       Attendance[]
  verifications    QualityVerification[]
  ratings          Rating[]
  notifications    Notification[]

  @@index([country])
  @@index([is_active])
  @@index([city, country])
}

// HotelWorker: roster — which workers are affiliated with a hotel and at what rate.
// A worker must be on the hotel's roster before being eligible for its WorkRequests.
model HotelWorker {
  id          String            @id @default(cuid())
  hotel_id    String
  hotel       Hotel             @relation(fields: [hotel_id], references: [id], onDelete: Cascade)
  worker_id   String
  worker      User              @relation(fields: [worker_id], references: [id], onDelete: Cascade)
  position    String            // "cleaner" | "checker" | "housekeeper" | "supervisor"
  status      HotelWorkerStatus @default(ACTIVE)
  hourly_rate Decimal?          @db.Decimal(10, 2)
  currency    String            @default("EUR")
  notes       String?
  joined_at   DateTime          @default(now())
  left_at     DateTime?
  created_at  DateTime          @default(now())
  updated_at  DateTime          @updatedAt

  // A worker appears on a hotel's roster exactly once
  @@unique([hotel_id, worker_id])
  @@index([hotel_id])
  @@index([worker_id])
  @@index([status])
  @@index([position])
}

// =============================================================================
// MARKETPLACE MODULE
// =============================================================================

model WorkRequest {
  id                  String            @id @default(cuid())
  hotel_id            String
  hotel               Hotel             @relation(fields: [hotel_id], references: [id], onDelete: Cascade)
  created_by_id       String
  created_by          User              @relation("request_creator", fields: [created_by_id], references: [id], onDelete: Restrict)
  position            String            // required role for this shift
  workers_needed      Int               @default(1)
  workers_confirmed   Int               @default(0)
  shift_date          DateTime          @db.Date
  shift_start_time    String            // stored as HH:MM; derive full DateTime with hotel timezone
  shift_end_time      String
  hourly_rate         Decimal?          @db.Decimal(10, 2)
  currency            String            @default("EUR")
  description         String?
  requirements        String?           // free-text skill/cert requirements
  status              WorkRequestStatus @default(DRAFT)
  published_at        DateTime?
  expires_at          DateTime?
  filled_at           DateTime?
  cancelled_at        DateTime?
  cancellation_reason String?
  created_at          DateTime          @default(now())
  updated_at          DateTime          @updatedAt

  // Relations
  applications WorkApplication[]
  assignments  WorkerAssignment[]

  // workers_confirmed must never exceed workers_needed — enforced at app layer +
  // CHECK constraint added in migration
  @@index([hotel_id])
  @@index([created_by_id])
  @@index([status])
  @@index([shift_date])
  @@index([position])
  @@index([hotel_id, status, shift_date]) // hot path: "open shifts at hotel on date"
}

// WorkApplication: a worker expresses interest in a WorkRequest.
// Manager reviews and accepts or rejects; acceptance triggers WorkerAssignment creation.
model WorkApplication {
  id              String            @id @default(cuid())
  work_request_id String
  work_request    WorkRequest       @relation(fields: [work_request_id], references: [id], onDelete: Cascade)
  worker_id       String
  worker          User              @relation("applicant", fields: [worker_id], references: [id], onDelete: Cascade)
  reviewed_by_id  String?
  reviewed_by     User?             @relation("application_reviewer", fields: [reviewed_by_id], references: [id], onDelete: SetNull)
  status          ApplicationStatus @default(PENDING)
  cover_note      String?
  // Snapshot of worker's rating at application time — avoids joining WorkerOverallRating
  // on every marketplace listing query
  worker_rating_snapshot Float?
  reviewed_at     DateTime?
  rejection_reason String?
  applied_at      DateTime          @default(now())
  updated_at      DateTime          @updatedAt

  // One application per worker per request
  @@unique([work_request_id, worker_id])
  @@index([work_request_id])
  @@index([worker_id])
  @@index([status])
  @@index([applied_at])
}

model WorkerAssignment {
  id                     String           @id @default(cuid())
  work_request_id        String
  work_request           WorkRequest      @relation(fields: [work_request_id], references: [id], onDelete: Cascade)
  worker_id              String
  worker                 User             @relation("assigned_worker", fields: [worker_id], references: [id], onDelete: Cascade)
  hotel_id               String
  hotel                  Hotel            @relation(fields: [hotel_id], references: [id], onDelete: Cascade)
  assigned_by_id         String
  assigned_by            User             @relation("assignment_manager", fields: [assigned_by_id], references: [id], onDelete: Restrict)
  // Nullable so assignments can be created directly by managers without an application
  application_id         String?          @unique
  status                 AssignmentStatus @default(CONFIRMED)
  confirmed_at           DateTime         @default(now())
  started_at             DateTime?
  completed_at           DateTime?
  cancelled_at           DateTime?
  cancellation_reason    String?
  // Self-referential chain for reassignments
  previous_assignment_id String?
  previous_assignment    WorkerAssignment?  @relation("reassignment_chain", fields: [previous_assignment_id], references: [id], onDelete: SetNull)
  reassignments          WorkerAssignment[] @relation("reassignment_chain")
  updated_at             DateTime           @updatedAt

  // Relations — each assignment yields at most one attendance record, one QV, one rating
  attendance           Attendance?
  quality_verification QualityVerification?
  rating               Rating?

  // One confirmed/active slot per worker per request prevents double-booking.
  // The partial unique index enforcing this for CONFIRMED/IN_PROGRESS rows is
  // created via raw SQL in the migration (Prisma cannot express partial indexes).
  @@unique([work_request_id, worker_id])
  @@index([work_request_id])
  @@index([worker_id])
  @@index([hotel_id])
  @@index([status])
  @@index([confirmed_at])
}

// =============================================================================
// ATTENDANCE MODULE
// =============================================================================

model Attendance {
  id             String           @id @default(cuid())
  assignment_id  String           @unique // 1-to-1 with WorkerAssignment
  assignment     WorkerAssignment @relation(fields: [assignment_id], references: [id], onDelete: Cascade)
  worker_id      String
  worker         User             @relation("attendee", fields: [worker_id], references: [id], onDelete: Cascade)
  hotel_id       String
  hotel          Hotel            @relation(fields: [hotel_id], references: [id], onDelete: Cascade)
  status         AttendanceStatus @default(PRESENT)
  check_in_at    DateTime?
  check_out_at   DateTime?
  // Denormalised from WorkRequest so payroll/reporting queries don't need an extra join
  expected_start DateTime?
  expected_end   DateTime?
  minutes_late   Int?
  minutes_worked Int?
  notes          String?
  verified_by_id String?
  verified_by    User?            @relation("attendance_verifier", fields: [verified_by_id], references: [id], onDelete: SetNull)
  verified_at    DateTime?
  created_at     DateTime         @default(now())
  updated_at     DateTime         @updatedAt

  @@index([worker_id])
  @@index([hotel_id])
  @@index([status])
  @@index([check_in_at])
  @@index([worker_id, check_in_at]) // "worker's shifts in date range"
}

// =============================================================================
// QUALITY MODULE
// =============================================================================

model QualityVerification {
  id               String             @id @default(cuid())
  assignment_id    String             @unique // 1-to-1 with WorkerAssignment
  assignment       WorkerAssignment   @relation(fields: [assignment_id], references: [id], onDelete: Cascade)
  hotel_id         String
  hotel            Hotel              @relation(fields: [hotel_id], references: [id], onDelete: Cascade)
  verified_by_id   String
  verified_by      User               @relation("verifier", fields: [verified_by_id], references: [id], onDelete: Restrict)
  score            Int                // 0–100
  status           VerificationStatus @default(PASSED)
  notes            String?
  photo_urls       String[]           // evidence uploaded to object storage
  rework_required  Boolean            @default(false)
  rework_notes     String?
  rework_completed_at DateTime?
  created_at       DateTime           @default(now())
  updated_at       DateTime           @updatedAt

  // score must be 0–100 — CHECK constraint in migration
  @@index([hotel_id])
  @@index([verified_by_id])
  @@index([status])
  @@index([score])
}

model Rating {
  id            String           @id @default(cuid())
  assignment_id String           @unique // 1-to-1 with WorkerAssignment
  assignment    WorkerAssignment @relation(fields: [assignment_id], references: [id], onDelete: Cascade)
  hotel_id      String
  hotel         Hotel            @relation(fields: [hotel_id], references: [id], onDelete: Cascade)
  worker_id     String
  worker        User             @relation("rated_worker", fields: [worker_id], references: [id], onDelete: Cascade)
  rated_by_id   String
  rated_by      User             @relation("rater", fields: [rated_by_id], references: [id], onDelete: Restrict)
  score         Int              // 1–5 stars
  comment       String?
  // Structured sub-scores; schema: { punctuality: Int, quality: Int, attitude: Int }
  criteria_scores Json?
  created_at    DateTime         @default(now())
  updated_at    DateTime         @updatedAt

  // score must be 1–5 — CHECK constraint in migration
  @@index([hotel_id])
  @@index([worker_id])
  @@index([rated_by_id])
  @@index([score])
  @@index([created_at])
}

// Materialised aggregate — updated by a DB trigger or app-layer upsert after each Rating write.
// Avoids expensive AVG() scans on marketplace listing pages.
model WorkerOverallRating {
  id               String    @id @default(cuid())
  worker_id        String    @unique
  worker           User      @relation(fields: [worker_id], references: [id], onDelete: Cascade)
  average_score    Float     // rolling average of Rating.score
  total_ratings    Int       @default(0)
  total_assignments Int      @default(0)
  completion_rate  Float     @default(0.0) // completed / total assignments
  on_time_rate     Float     @default(0.0) // present-on-time / total assignments
  last_worked_at   DateTime?
  updated_at       DateTime  @updatedAt

  @@index([average_score])
  @@index([total_ratings])
}

// =============================================================================
// NOTIFICATIONS MODULE
// =============================================================================

model Notification {
  id         String              @id @default(cuid())
  user_id    String
  user       User                @relation(fields: [user_id], references: [id], onDelete: Cascade)
  hotel_id   String?
  hotel      Hotel?              @relation(fields: [hotel_id], references: [id], onDelete: SetNull)
  type       String              // e.g. "APPLICATION_ACCEPTED" | "SHIFT_REMINDER" | "RATING_RECEIVED"
  channel    NotificationChannel @default(IN_APP)
  title      String
  message    String
  data       Json?               // resource IDs for deep-linking
  is_read    Boolean             @default(false)
  read_at    DateTime?
  sent_at    DateTime?
  expires_at DateTime?
  created_at DateTime            @default(now())

  @@index([user_id])
  @@index([hotel_id])
  @@index([type])
  @@index([created_at])
  @@index([user_id, is_read]) // hot path: unread notification badge count
}

// =============================================================================
// COMPLIANCE MODULE
// =============================================================================

model AuditLog {
  id            String    @id @default(cuid())
  actor_id      String?
  actor         User?     @relation(fields: [actor_id], references: [id], onDelete: SetNull)
  actor_role    UserRole?
  action        String    // "CREATE" | "READ" | "UPDATE" | "DELETE" | "APPROVE" | "REJECT" | "ASSIGN"
  resource_id   String
  resource_type String    // "WORK_REQUEST" | "APPLICATION" | "ASSIGNMENT" | "ATTENDANCE" | "RATING" etc.
  old_values    Json?     // previous state snapshot for UPDATE/DELETE
  new_values    Json?     // new state snapshot for CREATE/UPDATE
  details       Json?     // additional freeform context
  ip_address    String?
  user_agent    String?
  timestamp     DateTime  @default(now())

  // AuditLog rows are never mutated; no updated_at
  @@index([actor_id])
  @@index([action])
  @@index([resource_type])
  @@index([resource_id])
  @@index([timestamp])
  @@index([resource_type, resource_id]) // "full history of a resource"
}
