{
  "name": "hotel-crm-backend",
  "version": "0.1.0",
  "description": "Hotel CRM - Modular Monolith MVP",
  "main": "dist/server.js",
  "type": "module",
  "scripts": {
    "postinstall": "prisma generate",
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "db:migrate": "prisma migrate dev",
    "migrate:deploy": "prisma migrate deploy",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "db:seed": "tsx prisma/seed.ts",
    "test": "jest --forceExit",
    "test:coverage": "jest --coverage --forceExit"
  },
  "keywords": ["hotel", "crm", "monolith", "modular"],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@prisma/client": "^5.12.0",
    "bcryptjs": "^2.4.3",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.2",
    "winston": "^3.11.0",
    "zod": "^3.22.4",
    "dotenv": "^16.3.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.12",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^20.10.6",
    "@types/supertest": "^6.0.2",
    "@eslint/js": "^9.0.0",
    "eslint": "^9.0.0",
    "typescript-eslint": "^8.0.0",
    "jest": "^29.7.0",
    "prisma": "^5.12.0",
    "supertest": "^6.3.4",
    "ts-jest": "^29.1.4",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3"
  },
  "jest": {
    "preset": "ts-jest/presets/default-esm",
    "testEnvironment": "node",
    "extensionsToTreatAsEsm": [".ts"],
    "moduleNameMapper": {
      "^(\\.{1,2}/.*)\\.js$": "$1"
    },
    "transform": {
      "^.+\\.tsx?$": ["ts-jest", {
        "useESM": true,
        "tsconfig": {
          "module": "ESNext",
          "moduleResolution": "node"
        }
      }]
    },
    "testMatch": ["**/__tests__/**/*.test.ts"],
    "collectCoverageFrom": [
      "src/modules/**/*.ts",
      "src/middleware/**/*.ts",
      "src/lib/**/*.ts",
      "!src/**/*.d.ts"
    ]
  }
}
